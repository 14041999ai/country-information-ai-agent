# Copy this file to .env and fill in your values
# Groq API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# Groq model name (optional, defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# REST Countries API base URL (optional, defaults to the public API)
COUNTRIES_API_BASE_URL=https://restcountries.com/v3.1

# HTTP request timeout in seconds (optional, default 10)
COUNTRIES_API_TIMEOUT=10

# FastAPI server host and port (optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
